{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Open Google Chrome by control + command + g",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "g",
                                    "modifiers": {
                                        "mandatory": ["control", "command"],
                                        "optional": []
                                    }
                                },
                                "to": [{ "shell_command": "open -na 'Google Chrome'" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Books only: j/k -> Right/Left",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.apple\\.iBooksX$"
                                        ],
                                        "type": "frontmost_application_if"
                                    }
                                ],
                                "from": { "key_code": "k" },
                                "to": [{ "key_code": "left_arrow" }],
                                "type": "basic"
                            },
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.apple\\.iBooksX$"
                                        ],
                                        "type": "frontmost_application_if"
                                    }
                                ],
                                "from": { "key_code": "j" },
                                "to": [{ "key_code": "right_arrow" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Open iTerm by control + command + t",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "t",
                                    "modifiers": {
                                        "mandatory": ["control", "command"],
                                        "optional": []
                                    }
                                },
                                "to": [{ "shell_command": "osascript -e 'tell application \"iTerm2\" to create window with default profile'" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Open Firefox by control + command + f",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "f",
                                    "modifiers": {
                                        "mandatory": ["control", "command"],
                                        "optional": []
                                    }
                                },
                                "to": [{ "shell_command": "open -na Firefox" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "change control+[n/p] to [down_arrow/up_arrow]",
                        "enabled": false,
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "n",
                                    "modifiers": {
                                        "mandatory": ["left_control"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [
                                    {
                                        "key_code": "down_arrow",
                                        "modifiers": []
                                    }
                                ],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "p",
                                    "modifiers": {
                                        "mandatory": ["left_control"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [
                                    {
                                        "key_code": "up_arrow",
                                        "modifiers": []
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "devices": [
                {
                    "identifiers": { "is_keyboard": true },
                    "simple_modifications": [
                        {
                            "from": { "key_code": "backslash" },
                            "to": [{ "key_code": "delete_or_backspace" }]
                        },
                        {
                            "from": { "key_code": "delete_or_backspace" },
                            "to": [{ "key_code": "backslash" }]
                        }
                    ]
                }
            ],
            "name": "Default profile",
            "selected": true,
            "simple_modifications": [
                {
                    "from": { "key_code": "caps_lock" },
                    "to": [{ "key_code": "left_control" }]
                }
            ],
            "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" }
        }
    ]
}